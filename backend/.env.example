APP_NAME="Auction Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database ---
# Docker Compose: use pgsql + DB_HOST=postgres (see docker-compose.yml)
# Laragon/local:  use pgsql + DB_HOST=127.0.0.1 and enable pdo_pgsql in php.ini
# Quick local (no Postgres extension): use sqlite (see README)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=auction
DB_USERNAME=auction
DB_PASSWORD=secret

# SQLite alternative (uncomment and comment pgsql lines above):
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=redis
SESSION_LIFETIME=120
AUTH_REMEMBER_MINUTES=400
SESSION_ENCRYPT=false
# Leave empty for localhost dev (SPA on :5173 and API on :8080 via proxy or nginx)
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:8080,127.0.0.1:5173,127.0.0.1:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

REVERB_APP_ID=auction
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8081
VITE_REVERB_SCHEME=http
