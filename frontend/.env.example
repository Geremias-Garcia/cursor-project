# Vite dev server → Laravel proxy target (NOT sent to the browser).
# Host machine: nginx published on 8080
VITE_PROXY_TARGET=http://127.0.0.1:8080

# Docker Compose frontend service uses http://nginx:80 (set in docker-compose.yml).

# Browser fetch base URL. Leave empty for Sanctum SPA (recommended):
# - relative /api and /sanctum URLs
# - Vite proxy (port 5173) or Nginx (port 8080) forwards to Laravel
# VITE_API_BASE_URL=

# Only set when the SPA and API are truly separate origins with CORS configured.
# VITE_API_BASE_URL=http://localhost:8080
